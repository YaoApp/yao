# ============================================
# Agent Test Environment Configuration
# Single source of truth for all test environment settings.
# Startup scripts read this file and generate the Yao app's .env from it.
# CI overrides variables as needed (e.g., switching DB driver).
#
# Copy this file to agent-test.env and fill in your API keys:
#   cp agent-test.env.template agent-test.env
# ============================================

# ============================================
# Path Configuration
# ============================================
# Resolved automatically by scripts; CI can override.
# TEST_APP_DIR    -- test application directory (unit-test/agent/app)
# TEST_BUILD_DIR  -- compiled binaries ($YAO_SRC/.build/test)
# TEST_DATA_DIR   -- runtime data: PID files, Tai credentials ($TEST_BUILD_DIR/data)

# ============================================
# Database (CI can override to postgres/mysql)
# ============================================
YAO_DB_DRIVER=sqlite3
YAO_DB_PRIMARY=./db/agent-test.db

# PostgreSQL example:
# YAO_DB_DRIVER=postgres
# YAO_DB_PRIMARY=postgres://yao:yao@127.0.0.1:5432/agent_test?sslmode=disable

# MySQL example:
# YAO_DB_DRIVER=mysql
# YAO_DB_PRIMARY=root:test@tcp(127.0.0.1:3306)/agent_test?charset=utf8mb4&parseTime=True

# ============================================
# Yao Server
# ============================================
YAO_ENV=development
YAO_HOST=127.0.0.1
YAO_PORT=6099
YAO_GRPC_HOST=127.0.0.1
YAO_GRPC_PORT=6199
YAO_JWT_SECRET=test-jwt-secret-agent-unit
YAO_DB_AESKEY=test-aes-key-agent-unit!
YAO_LOG=./logs/application.log
YAO_LOG_MODE=TEXT
YAO_SESSION_STORE=file
YAO_SESSION_FILE=./db/.session
YAO_CLIENT_ID=test-agent-client-id-00000000000

# ============================================
# Mock LLM Server
# ============================================
MOCK_LLM_PORT=6920
MOCK_LLM_HOST=http://127.0.0.1:6920

# ============================================
# Tai Docker Instance (Tunnel mode)
# ============================================
TAI_DOCKER_GRPC_PORT=6100
TAI_DOCKER_ADDR=127.0.0.1:6100
TAI_DOCKER_DATA_DIR=$TEST_DATA_DIR/tai-docker

# ============================================
# Tai HostExec Instance (Tunnel mode)
# ============================================
TAI_HOSTEXEC_GRPC_PORT=6110
TAI_HOSTEXEC_ADDR=127.0.0.1:6110
TAI_HOSTEXEC_DATA_DIR=$TEST_DATA_DIR/tai-hostexec

# ============================================
# Sandbox Test Config (Go test reads these)
# ============================================
SANDBOX_TEST_LOCAL_ADDR=
SANDBOX_TEST_IMAGE=alpine:latest

# ============================================
# LLM API Keys (E2E tests)
# Fill in your keys below. CI injects from secrets.
# ============================================
DEEPSEEK_V4_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SERPAPI_API_KEY=
