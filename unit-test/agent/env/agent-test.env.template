# ============================================
# Agent Test Environment Configuration
#
# This file is the SINGLE SOURCE OF TRUTH for the test environment.
# All key=val lines (except TEST_*/SANDBOX_TEST_*) are written into
# app/.env by testprepare and by the shell generate_yao_env() function.
# Yao's config.Init() loads app/.env via godotenv.Overload, and
# connectors resolve $ENV.* variables from that file.
#
# Copy this file to agent-test.env and fill in your API keys:
#   cp agent-test.env.template agent-test.env
#
# Local overrides: create env/.env.local (gitignored) to override
# API keys or DB settings without modifying this file.
# ============================================

# ============================================
# Database
# ============================================
# Default: sqlite3 for zero-config local development.
# CI can override to postgres via .env.local or env injection.
#
# PostgreSQL example:
#   YAO_DB_DRIVER=postgres
#   YAO_DB_PRIMARY=postgres://yao:yao@127.0.0.1:5432/agent_test?sslmode=disable
YAO_DB_DRIVER=sqlite3
YAO_DB_PRIMARY=./db/agent-test.db

# ============================================
# Yao Server
# ============================================
YAO_ENV=development
YAO_HOST=127.0.0.1
YAO_PORT=6099
YAO_GRPC_HOST=127.0.0.1
YAO_GRPC_PORT=6199
YAO_JWT_SECRET=test-jwt-secret-agent-unit
YAO_DB_AESKEY=test-aes-key-agent-unit!
YAO_LOG=./logs/application.log
YAO_LOG_MODE=TEXT
YAO_SESSION_STORE=file
YAO_SESSION_FILE=./db/.session
YAO_CLIENT_ID=test-agent-client-id-00000000000

# ============================================
# Mock LLM Server (external process)
# ============================================
# Connectors reference this via $ENV.MOCK_LLM_HOST
MOCK_LLM_PORT=6920
MOCK_LLM_HOST=http://host.tai.internal:6920

# ============================================
# LLM API Keys
# ============================================
# Connectors reference these via $ENV.OPENAI_API_KEY etc.
# Local: fill in env/.env.local; CI: injected from secrets.
DEEPSEEK_V4_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SERPAPI_API_KEY=
SERPER_API_KEY=

# ============================================
# Sandbox Test Config (Go test reads these)
# ============================================
SANDBOX_TEST_LOCAL_ADDR=
SANDBOX_TEST_IMAGE=yaoapp/tai-sandbox-base:latest
