{
  "name": "Mail",
  "label": "Mail",
  "description": "Inbox mail notifications generated by task status changes",
  "tags": ["agent", "system"],
  "builtin": true,
  "readonly": true,
  "sort": 9999,
  "table": { "name": "agent_mail", "comment": "Agent mail table" },
  "columns": [
    {
      "name": "id",
      "type": "ID",
      "label": "ID",
      "comment": "Auto-increment primary key"
    },
    {
      "name": "mail_id",
      "type": "string",
      "label": "Mail ID",
      "comment": "Unique mail identifier",
      "length": 64,
      "nullable": false,
      "unique": true
    },
    {
      "name": "type",
      "type": "enum",
      "label": "Type",
      "comment": "Mail type",
      "option": ["input", "completed", "failed", "update"],
      "nullable": false
    },
    {
      "name": "priority",
      "type": "enum",
      "label": "Priority",
      "comment": "Mail priority",
      "option": ["high", "medium", "low"],
      "default": "low",
      "nullable": false
    },
    {
      "name": "title",
      "type": "string",
      "label": "Title",
      "comment": "Mail title",
      "length": 500,
      "nullable": false
    },
    {
      "name": "body",
      "type": "text",
      "label": "Body",
      "comment": "Mail content",
      "nullable": true
    },
    {
      "name": "chat_id",
      "type": "string",
      "label": "Chat ID",
      "comment": "Associated chat/task identifier",
      "length": 64,
      "nullable": false,
      "index": true
    },
    {
      "name": "assistant_id",
      "type": "string",
      "label": "Assistant ID",
      "comment": "Associated AI assistant",
      "length": 64,
      "nullable": true
    },
    {
      "name": "source_type",
      "type": "string",
      "label": "Source Type",
      "comment": "Source type (kanban/schedule/system)",
      "length": 50,
      "nullable": true
    },
    {
      "name": "source_id",
      "type": "string",
      "label": "Source ID",
      "comment": "Source identifier (e.g. board_id)",
      "length": 64,
      "nullable": true
    },
    {
      "name": "source_name",
      "type": "string",
      "label": "Source Name",
      "comment": "Source display name (denormalized)",
      "length": 200,
      "nullable": true
    },
    {
      "name": "read",
      "type": "boolean",
      "label": "Read",
      "comment": "Whether mail has been read",
      "default": false,
      "index": true
    },
    {
      "name": "starred",
      "type": "boolean",
      "label": "Starred",
      "comment": "Whether mail is starred",
      "default": false
    },
    {
      "name": "pinned",
      "type": "boolean",
      "label": "Pinned",
      "comment": "Whether mail is pinned",
      "default": false
    },
    {
      "name": "read_at",
      "type": "datetime",
      "label": "Read At",
      "comment": "Time when mail was read",
      "nullable": true
    },
    {
      "name": "metadata",
      "type": "json",
      "label": "Metadata",
      "comment": "Additional metadata",
      "nullable": true
    }
  ],
  "indexes": [
    {
      "name": "idx_read_type",
      "columns": ["read", "type"]
    },
    {
      "name": "idx_source",
      "columns": ["source_type", "source_id"]
    }
  ],
  "relations": {
    "task": {
      "type": "hasOne",
      "model": "__yao.agent.task",
      "key": "chat_id",
      "foreign": "chat_id"
    }
  },
  "option": { "timestamps": true, "soft_deletes": true, "permission": true }
}
