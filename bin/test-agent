#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
YAO_SRC="$(cd "$SCRIPT_DIR/.." && pwd)"
AGENT_DIR="$YAO_SRC/unit-test/agent"
SCRIPTS_DIR="$AGENT_DIR/scripts"

usage() {
  cat <<EOF
Usage: bin/test-agent <command> [options]

Commands:
  start       Start mock-llm server
  stop        Stop mock-llm server
  run         Run tests (start mock-llm first if not running)

Options for 'run':
  --tier <name>   Test tier (default: all)
        unit      Pure unit tests only (no Yao Runtime, no Docker, no LLM)
        sandbox   Full Yao Runtime + Tai + Docker tests
        e2e       E2E tests (Runtime + Tai + Mock LLM)
        all       All tests (unit + sandbox + e2e)
  --coverage      Generate coverage report
  --verbose       Enable verbose output (go test -v)
  --pkg <path>    Specific package to test (e.g. ./agent/llm/...)
  --run <regex>   Specific test function regex
  --count <n>     go test -count (default: 1)
  --timeout <dur> go test -timeout (default: 600s)

Examples:
  bin/test-agent start                    # Start mock-llm
  bin/test-agent run                      # Run all tests
  bin/test-agent run --tier unit          # Pure unit tests (fast, no deps)
  bin/test-agent run --tier sandbox       # Sandbox tests (needs Docker)
  bin/test-agent run --tier e2e           # E2E tests (needs mock-llm + Docker)
  bin/test-agent run --pkg ./agent/llm/... --run TestStream
  bin/test-agent stop                     # Stop mock-llm
EOF
}

cmd_start() {
  "$SCRIPTS_DIR/start-mock-llm.sh"
}

cmd_stop() {
  "$SCRIPTS_DIR/stop-mock-llm.sh"
}

mock_llm_running() {
  source "$SCRIPTS_DIR/_common.sh"
  load_env
  local pidfile="$DATA_DIR/pids/mock-llm.pid"
  if [ -f "$pidfile" ]; then
    local pid
    pid=$(cat "$pidfile" 2>/dev/null) || return 1
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && return 0
  fi
  return 1
}

cmd_run() {
  local tier="all"
  local coverage=""
  local verbose=""
  local pkg=""
  local run_regex=""
  local count="1"
  local timeout="600s"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tier)    tier="$2"; shift 2 ;;
      --coverage) coverage="-coverprofile=coverage.out"; shift ;;
      --verbose)  verbose="-v"; shift ;;
      --pkg)     pkg="$2"; shift 2 ;;
      --run)     run_regex="$2"; shift 2 ;;
      --count)   count="$2"; shift 2 ;;
      --timeout) timeout="$2"; shift 2 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  # Start mock-llm if not running (needed for e2e and all)
  if [[ "$tier" == "e2e" || "$tier" == "all" ]]; then
    if ! mock_llm_running; then
      echo "[INFO] mock-llm not running, starting..."
      cmd_start
    fi
  fi

  # Load environment for test variables
  source "$SCRIPTS_DIR/_common.sh"
  load_env

  # Export paths for Go test framework
  export YAO_AGENT_TEST_APPLICATION="$APP_DIR"
  export YAO_TEST_APPLICATION="$APP_DIR"
  export YAO_ROOT="$APP_DIR"

  # Determine test packages and run filter by tier
  if [ -n "$pkg" ]; then
    test_pkgs="$pkg"
  else
    case "$tier" in
      unit)
        test_pkgs="./sandbox/v2/... ./agent/sandbox/v2/..."
        ;;
      sandbox)
        test_pkgs="./sandbox/v2/... ./agent/sandbox/v2"
        ;;
      e2e)
        test_pkgs="./agent/sandbox/v2/yaocode ./agent/sandbox/v2/opencode ./agent/sandbox/v2/claude"
        ;;
      all)
        test_pkgs="./sandbox/v2/... ./agent/sandbox/v2/..."
        ;;
      *)
        echo "Unknown tier: $tier"; exit 1
        ;;
    esac
  fi

  # Build go test arguments
  local go_args=("test")
  [ -n "$verbose" ] && go_args+=("$verbose")
  [ -n "$coverage" ] && go_args+=("$coverage")
  go_args+=("-count=$count")
  [ -n "$run_regex" ] && go_args+=("-run" "$run_regex")
  go_args+=("-timeout" "$timeout")
  # shellcheck disable=SC2206
  go_args+=($test_pkgs)

  echo ""
  echo "=== Running Agent Tests ==="
  echo "  Tier:    $tier"
  echo "  Pkgs:    $test_pkgs"
  echo "  App:     $APP_DIR"
  echo "  Command: go ${go_args[*]}"
  echo ""

  cd "$YAO_SRC"
  go "${go_args[@]}"
}

# Main
if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

command="$1"
shift

case "$command" in
  start) cmd_start ;;
  stop)  cmd_stop ;;
  run)   cmd_run "$@" ;;
  -h|--help|help) usage ;;
  *) echo "Unknown command: $command"; usage; exit 1 ;;
esac
